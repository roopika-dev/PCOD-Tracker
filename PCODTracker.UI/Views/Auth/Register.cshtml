@model PCODTracker.Web.Models.UserViewModel

@{
    ViewData["Title"] = "Register";
}

<style>

    body {
        background: linear-gradient(135deg,#a18cd1,#fbc2eb);
        min-height: 100vh;
    }

    .auth-container {
        width: 100%;
        max-width: 380px;
        margin: 60px auto;
        background: white;
        border-radius: 25px;
        padding: 35px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        animation: fadeIn 0.8s ease;
    }

    .logo {
        font-size: 55px;
        text-align: center;
        margin-bottom: 10px;
    }

    .title {
        text-align: center;
        font-size: 32px;
        font-weight: bold;
        color: #7b2cbf;
        margin-bottom: 5px;
    }

    .subtitle {
        text-align: center;
        color: gray;
        margin-bottom: 30px;
    }

    .input-box {
        margin-bottom: 20px;
    }

        .input-box input {
            width: 100%;
            border: none;
            outline: none;
            background: #f4f4f4;
            padding: 15px;
            border-radius: 15px;
            font-size: 16px;
            transition: 0.3s;
        }

            .input-box input:focus {
                background: #efe3ff;
                transform: scale(1.02);
            }

    .register-btn {
        width: 100%;
        border: none;
        padding: 15px;
        border-radius: 15px;
        background: linear-gradient(90deg,#7b2cbf,#9d4edd);
        color: white;
        font-size: 18px;
        font-weight: bold;
        transition: 0.3s;
    }

        .register-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(123,44,191,0.4);
        }

    .bottom-text {
        text-align: center;
        margin-top: 20px;
    }

        .bottom-text a {
            text-decoration: none;
            color: #7b2cbf;
            font-weight: bold;
        }

    .success-msg {
        color: green;
        text-align: center;
        margin-top: 15px;
    }

    @@keyframes fadeIn {

        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

</style>

<div class="auth-container">

    <div class="logo">🌸</div>

    <div class="title">Create Account</div>

    <div class="subtitle">
        Start your PCOD journey
    </div>

    <form method="post">

        <div class="input-box">
            <input asp-for="Email" placeholder="Email Address" />
        </div>

        <div class="input-box">
            <input asp-for="Password"
                   type="password"
                   placeholder="Password" />
        </div>

        <button type="submit" class="register-btn">
            Register
        </button>

    </form>

    @if (ViewBag.Result != null)
    {
        <div class="success-msg">
            @ViewBag.Result
        </div>
    }

    <div class="bottom-text">
        Already have account?
        <a href="/Auth/Login">Login</a>
    </div>

</div>